# คัดลอกไฟล์นี้เป็น .env แล้วปรับค่าให้ตรงสภาพแวดล้อม (ห้าม commit .env จริง)

# ── Base path (sub-folder deployment ใต้โดเมนกลาง — ดู SRS NFR-9) ──
BASE_PATH=/aipack

# ── Auth.js / NextAuth ──
# หมายเหตุสำคัญ: ต้องชี้ไปที่ path ของ auth routes เอง ("<origin><basePath>/api/auth")
# ไม่ใช่แค่ root ของแอป — next-auth ใช้ pathname ของค่านี้เป็น internal route prefix
# (config.basePath) เพื่อ parse action จาก request path (/providers, /callback/google, ...)
# และสร้าง redirect_uri ที่ส่งให้ Google — คู่กับ wrapper ใน
# src/app/api/auth/[...nextauth]/route.ts ที่เติม basePath กลับเข้า req.url ก่อนส่งให้ next-auth
# (Next.js เวอร์ชันนี้ตัด basePath ออกจาก req.url ใน Route Handler ไปแล้ว) ดูรายละเอียดใน src/auth.ts
NEXTAUTH_URL=http://localhost:3000/aipack/api/auth
NEXTAUTH_SECRET=changeme

# ── Database (Prisma / Postgres) ──
DATABASE_URL=postgresql://alpr:alpr@postgres:5432/alpr

# ── Storage (MinIO / S3-compatible) ──
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio12345
# presigned URL (ดาวน์โหลดแผน/รายงาน PDF) ต้องเซ็นด้วย endpoint ที่ browser ผู้ใช้เข้าถึงได้จริง
# ไม่ใช่ "minio" (ชื่อ host ภายใน docker network) — dev ใช้ localhost ที่ map พอร์ตออกมาแล้ว
# prod ต้องตั้งเป็นโดเมนจริงที่ MinIO เปิดให้เข้าถึงจากภายนอก (เช่น https://storage.example.com)
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# ── Google OAuth (FR-1 — วิธีเข้าสู่ระบบเดียว) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Domain allow-list (comma-separated, ว่าง = ไม่จำกัด — dev only) ──
ALLOWED_EMAIL_DOMAINS=ksu.ac.th

# ── Admin allow-list (comma-separated) ──
# อีเมลในรายการนี้จะถูกยกระดับเป็น role=admin โดยอัตโนมัติทุกครั้งที่ล็อกอิน (ทั้งบัญชีใหม่และเก่า)
# ผู้ใช้ทั่วไปที่ไม่อยู่ในรายการนี้จะได้ role=cat + status=active ทันทีตั้งแต่ล็อกอินครั้งแรก
# (ไม่ต้องรอ admin กำหนดบทบาท) — admin เปลี่ยนบทบาทคนอื่นเพิ่มเติมได้ที่หน้า /admin/users
ADMIN_EMAILS=sarayut.go@ksu.ac.th

# ── AI Evaluator (pluggable — gemini | openai) ──
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── PDF report font (ดู assets/fonts/README.md) ──
REPORT_FONT_PATH=assets/fonts/IBMPlexSansThai-Regular.ttf

// ALPR — Prisma schema
// แปลงจาก design_database_schema.md v1.1 (13 ตาราง)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── ENUMS ───────────────────────────

enum UserRole {
  cat
  cam
  admin

  @@map("user_role")
}

enum UserStatus {
  active
  pending_role
  disabled

  @@map("user_status")
}

enum PlanStatus {
  uploaded
  processing
  ai_pending
  waiting_cam
  in_review
  done
  failed

  @@map("plan_status")
}

enum FileType {
  pdf
  docx

  @@map("file_type")
}

enum AiProvider {
  gemini
  openai
  claude

  @@map("ai_provider")
}

enum QualityBand {
  innovative_master // 17–20
  fluent // 13–16
  developing // 9–12  ⚠️ ห้ามใช้สอนทันที
  emerging // 5–8

  @@map("quality_band")
}

// ─────────────────────────── AUTH (Auth.js, DB session — มติ ③) ───────────────────────────

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────── CORE ───────────────────────────

model School {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  code       String?  @unique
  district   String?
  province   String   @default("กาฬสินธุ์")
  createdAt  DateTime @default(now()) @map("created_at")

  users User[]

  @@index([name])
  @@map("schools")
}

model User {
  id         String     @id @default(uuid()) @db.Uuid
  // nullable: PrismaAdapter สร้าง user ก่อนรู้ providerAccountId แล้ว backfill ใน linkAccount()
  googleSub  String?    @unique @map("google_sub")
  email      String     @unique
  name       String
  avatarUrl  String?    @map("avatar_url")
  role       UserRole   @default(cat)
  status     UserStatus @default(pending_role)
  schoolId   String?    @map("school_id") @db.Uuid
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  school   School?  @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  accounts Account[]
  sessions Session[]

  // ความสัมพันธ์ mentor-mentee
  mentorLinksAsCam MentorLink[] @relation("CamLinks")
  mentorLinksAsCat MentorLink[] @relation("CatLinks")

  lessonPlans      LessonPlan[]       @relation("PlanOwner")
  finalEvaluations FinalEvaluation[]  @relation("CamEvaluator")
  auditLogs        AuditLog[]         @relation("ChangedBy")

  @@index([role])
  @@index([schoolId])
  @@map("users")
}

model MentorLink {
  id        String   @id @default(uuid()) @db.Uuid
  camId     String   @map("cam_id") @db.Uuid
  catId     String   @map("cat_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  cam User @relation("CamLinks", fields: [camId], references: [id], onDelete: Cascade)
  cat User @relation("CatLinks", fields: [catId], references: [id], onDelete: Cascade)

  @@unique([camId, catId])
  @@index([catId])
  @@map("mentor_links")
}

// ─────────────────────────── RUBRIC (มติ ④ — ตารางอ้างอิง) ───────────────────────────

model RubricVersion {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique // เช่น "aipack-v1"
  maxScore  Int      @default(20)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  criteria        RubricCriterion[]
  aiEvaluations   AiEvaluation[]
  finalEvaluations FinalEvaluation[]

  @@map("rubric_versions")
}

model RubricCriterion {
  id              String   @id @default(uuid()) @db.Uuid
  rubricVersionId String   @map("rubric_version_id") @db.Uuid
  code            String // 'C1'..'C5'
  title           String
  maxLevel        Int      @default(4)
  descriptors     Json // [{level:4, text:"..."}, ...]
  signals         Json? // เช่น ["prompt","socratic","rubric","fact_check","think_trail"]
  sortOrder       Int      @default(0) @map("sort_order")

  rubricVersion RubricVersion @relation(fields: [rubricVersionId], references: [id], onDelete: Cascade)

  @@unique([rubricVersionId, code])
  @@map("rubric_criteria")
}

// ─────────────────────────── LESSON PLAN FLOW ───────────────────────────

model LessonPlan {
  id                 String     @id @default(uuid()) @db.Uuid
  catId              String     @map("cat_id") @db.Uuid
  subject            String
  topic              String?
  grade              String?
  version            Int        @default(1)
  previousVersionId  String?    @map("previous_version_id") @db.Uuid
  fileKey            String     @map("file_key") // MinIO object key (bucket: alpr-plans)
  fileType           FileType   @map("file_type")
  fileSizeBytes      BigInt?    @map("file_size_bytes")
  status             PlanStatus @default(uploaded)
  errorMessage       String?    @map("error_message")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  cat             User             @relation("PlanOwner", fields: [catId], references: [id], onDelete: Restrict)
  previousVersion LessonPlan?      @relation("PlanVersions", fields: [previousVersionId], references: [id], onDelete: SetNull)
  nextVersions    LessonPlan[]     @relation("PlanVersions")
  extraction      Extraction?
  aiEvaluations   AiEvaluation[]
  finalEvaluation FinalEvaluation?
  auditLogs       AuditLog[]

  @@index([catId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("lesson_plans")
}

model Extraction {
  planId    String   @id @map("plan_id") @db.Uuid
  text      String?  @db.Text
  ocrUsed   Boolean  @default(false) @map("ocr_used")
  pageCount Int?     @map("page_count")
  checklist Json     @default("[]") // เช็กลิสต์หลักฐาน 5 รายการ
  createdAt DateTime @default(now()) @map("created_at")

  plan LessonPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@map("extractions")
}

model AiEvaluation {
  id              String     @id @default(uuid()) @db.Uuid
  planId          String     @map("plan_id") @db.Uuid
  provider        AiProvider
  model           String
  rubricVersionId String     @map("rubric_version_id") @db.Uuid
  criteria        Json // ผลราย C1–C5 (level, reason, evidence[], confidence, no_evidence)
  suggestedTotal  Int?       @map("suggested_total")
  promptHash      String?    @map("prompt_hash")
  createdAt       DateTime   @default(now()) @map("created_at")

  plan          LessonPlan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  rubricVersion RubricVersion @relation(fields: [rubricVersionId], references: [id])

  @@index([planId, createdAt(sort: Desc)])
  @@map("ai_evaluations")
}

model FinalEvaluation {
  planId          String       @id @map("plan_id") @db.Uuid
  camId           String       @map("cam_id") @db.Uuid
  basedOnAiId     String?      @map("based_on_ai_id") @db.Uuid
  rubricVersionId String       @map("rubric_version_id") @db.Uuid
  criteriaFinal   Json         @map("criteria_final") // ราย C1–C5 ที่ CAM ยืนยัน
  total           Int
  band            QualityBand
  plcAction       String?      @map("plc_action")
  strengths       String?      @db.Text
  areasForGrowth  String?      @map("areas_for_growth") @db.Text
  reportKey       String?      @map("report_key") // MinIO (bucket: alpr-reports)
  signature       String?
  position        String?
  signedAt        DateTime?    @map("signed_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  plan          LessonPlan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  cam           User          @relation("CamEvaluator", fields: [camId], references: [id], onDelete: Restrict)
  rubricVersion RubricVersion @relation(fields: [rubricVersionId], references: [id])

  @@index([camId])
  @@map("final_evaluations")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  planId    String   @map("plan_id") @db.Uuid
  criterion String // 'C1'..'C5'
  aiLevel   Int?     @map("ai_level")
  camLevel  Int      @map("cam_level")
  changedBy String   @map("changed_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  plan LessonPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  user User       @relation("ChangedBy", fields: [changedBy], references: [id])

  @@index([planId, createdAt])
  @@map("audit_logs")
}
